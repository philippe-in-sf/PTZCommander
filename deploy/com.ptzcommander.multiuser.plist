<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.ptzcommander.multiuser</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd __ROOT__ &amp;&amp; /usr/bin/env PORT=__PORT__ NODE_ENV=production SESSION_SECRET=__SESSION_SECRET__ SESSION_COOKIE_SECURE=false npm run start</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__ROOT__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__ROOT__/deploy/logs/ptzcommander.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__ROOT__/deploy/logs/ptzcommander.stderr.log</string>
  </dict>
</plist>
