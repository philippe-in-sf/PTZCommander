# PTZ Command - Environment Configuration
# Copy this file to .env and update with your settings

# PostgreSQL Database Connection
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ptz_command

# Shared server port (default: 3478)
PORT=3478

# Session signing secret for shared/multi-user deployments
SESSION_SECRET=change-this-before-sharing-the-app

# Cookie security mode: true, false, or auto
SESSION_COOKIE_SECURE=auto

# Node Environment (development or production)
NODE_ENV=development
